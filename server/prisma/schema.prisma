generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  email        String?  @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  words        Word[]
  phrases      Phrase[]
  progress     UserProgress[]
  mistakes     MistakeLog[]
}

model Word {
  id              Int      @id @default(autoincrement())
  norwegianWord   String
  translation     String
  exampleSentence String?
  tags            String[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  userId          Int
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, norwegianWord])

}

model Phrase {
  id              Int      @id @default(autoincrement())
  norwegianPhrase String
  translation     String
  topic           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  userId          Int
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserProgress {
  id            Int      @id @default(autoincrement())
  itemType      String
  itemId        Int
  repetitions   Int      @default(0)
  intervalDays  Int      @default(1)
  easeFactor    Float    @default(2.5)
  nextReview    DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  userId        Int
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, itemType, itemId])
}

model MistakeLog {
  id          Int      @id @default(autoincrement())
  itemType    String
  itemId      Int
  mistakeText String
  correctText String
  createdAt   DateTime @default(now())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
